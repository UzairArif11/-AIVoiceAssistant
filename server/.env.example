# Server Configuration
PORT=3001
NODE_ENV=development

# AI Provider Configuration
# Options: openai, openrouter, gemini
AI_PROVIDER=openrouter

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY= 
OPENAI_MODEL=gpt-4o-mini

# OpenRouter Configuration (FREE models available)
OPENROUTER_API_KEY= 
OPENROUTER_MODEL=google/gemma-2-9b-it:free
# Free models: google/gemma-2-9b-it:free, meta-llama/llama-3.1-8b-instruct:free
# Paid models: openai/gpt-4o-mini, anthropic/claude-3-haiku

# Google Gemini Configuration (FREE tier: 60 requests/min)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Models: gemini-1.5-flash (fastest), gemini-1.5-pro (best quality)

# Speech-to-Text Configuration
STT_PROVIDER=web_speech  # Options: openai, web_speech, google

# Text-to-Speech Configuration
TTS_PROVIDER=web_speech  # Options: openai, web_speech, google

# Voice Activity Detection Settings
VAD_AGGRESSIVE_MODE=3  # 0-3, higher = more aggressive
MIN_SPEECH_DURATION=500  # milliseconds
MAX_SPEECH_DURATION=30000  # milliseconds

# AI Assistant Configuration
ASSISTANT_NAME=Assistant
MAX_RESPONSE_LENGTH=200
CONVERSATION_CONTEXT_LENGTH=10
